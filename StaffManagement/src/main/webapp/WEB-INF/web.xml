<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee                              https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <display-name>Staff Management</display-name>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>fu.swt301.sms.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ExportStaffServlet</servlet-name>
        <servlet-class>fu.swt301.sms.servlet.ExportStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ExportStaffServlet</servlet-name>
        <url-pattern>/export-staff</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
</web-app>
